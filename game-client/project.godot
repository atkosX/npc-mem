; Engine configuration file — Neighbourhood Echoes, Phase 2 game client.
; Open this folder in Godot 4.x.

config_version=5

[application]

config/name="Neighbourhood Echoes"
run/main_scene="res://Main.tscn"
config/features=PackedStringArray("4.3")
config/icon="res://icon.svg"

[autoload]

GameApi="*res://scripts/GameApi.gd"
DialogueUI="*res://scripts/DialogueUI.gd"

[display]

window/size/viewport_width=960
window/size/viewport_height=540
